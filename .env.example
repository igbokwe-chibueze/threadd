# Application
APP_ENV=development
APP_URL=http://localhost:3000
STORE_MODE=commerce

# Demo safeguards
DEMO_MODE=true
DEMO_RESET_SECRET=replace-with-a-long-random-value

# Email is intentionally local for the portfolio demo.
EMAIL_PROVIDER=demo_outbox
ADMIN_NOTIFICATION_EMAIL=admin@demo.threadd.store
# Optional. International format without +, for example 2348012345678.
WHATSAPP_PHONE_NUMBER=

# Added in Phase 2.
DATABASE_URL=postgresql://user:password@localhost:5432/threadd
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=http://localhost:3000

# Production-only, one-time server CLI bootstrap. Keep disabled normally.
ALLOW_SUPER_ADMIN_BOOTSTRAP=false
SUPER_ADMIN_NAME=THREADD Owner
SUPER_ADMIN_EMAIL=owner@example.com
SUPER_ADMIN_PASSWORD=replace-with-a-strong-unique-password

# Added in Phase 7. Use test credentials in the public demo.
PAYSTACK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_replace_me
