generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

enum AuditOutcome {
  SUCCESS
  DENIED
  FAILURE
}

enum EmailKind {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  ORDER_CONFIRMATION
  PAYMENT_CONFIRMATION
  ORDER_STATUS
  ENQUIRY_CONFIRMATION
  ADMIN_NOTIFICATION
}

enum EmailDeliveryStatus {
  PREVIEW_READY
  SENT
  FAILED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  emailVerified Boolean        @default(false)
  image         String?
  role          UserRole       @default(CUSTOMER)
  isDemoAccount Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  sessions      Session[]
  accounts      Account[]
  auditLogs     AuditLog[]     @relation("AuditActor")
  emailMessages EmailMessage[]

  @@index([role])
  @@index([createdAt])
}

model EmailMessage {
  id                String              @id @default(cuid())
  recipientEmail    String
  recipientUserId   String?
  subject           String
  textBody          String
  kind              EmailKind
  deliveryStatus    EmailDeliveryStatus @default(PREVIEW_READY)
  providerMessageId String?
  previewTokenHash  String?
  previewExpiresAt  DateTime?
  expiresAt         DateTime?
  createdAt         DateTime            @default(now())
  recipientUser     User?               @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([recipientUserId, createdAt])
  @@index([recipientEmail, createdAt])
  @@index([kind, createdAt])
  @@index([previewTokenHash, previewExpiresAt])
  @@index([expiresAt])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@index([identifier])
  @@index([expiresAt])
}

model AuditLog {
  id            String       @id @default(cuid())
  actorId       String?
  action        String
  resourceType  String
  resourceId    String?
  outcome       AuditOutcome @default(SUCCESS)
  correlationId String?
  metadata      Json?
  ipAddress     String?
  createdAt     DateTime     @default(now())
  actor         User?        @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([resourceType, resourceId])
  @@index([correlationId])
  @@index([createdAt])
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  position    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([position, name])
}

model Collection {
  id          String              @id @default(cuid())
  name        String
  slug        String              @unique
  description String?
  featured    Boolean             @default(false)
  position    Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  products    ProductCollection[]

  @@index([featured, position])
}

model Product {
  id               String              @id @default(cuid())
  name             String
  slug             String              @unique
  shortDescription String
  description      String
  status           ProductStatus       @default(DRAFT)
  basePrice        Decimal             @db.Decimal(12, 2)
  compareAtPrice   Decimal?            @db.Decimal(12, 2)
  featured         Boolean             @default(false)
  seoTitle         String?
  seoDescription   String?
  categoryId       String
  publishedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  category         Category            @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  collections      ProductCollection[]
  images           ProductImage[]
  variants         ProductVariant[]

  @@index([status, publishedAt])
  @@index([categoryId, status])
  @@index([featured, status])
  @@index([createdAt])
}

model ProductCollection {
  productId    String
  collectionId String
  position     Int        @default(0)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@index([collectionId, position])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  altText   String
  position  Int      @default(0)
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, position])
}

model ProductVariant {
  id                String   @id @default(cuid())
  productId         String
  sku               String   @unique
  size              String
  colour            String
  colourHex         String?
  priceAdjustment   Decimal  @default(0) @db.Decimal(12, 2)
  inventoryQuantity Int      @default(0)
  lowStockThreshold Int      @default(3)
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, size, colour])
  @@index([productId, active])
  @@index([size, active])
  @@index([colour, active])
  @@index([inventoryQuantity])
}
